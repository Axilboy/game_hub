# ——— Telegram ———
# Токен бота от @BotFather (обязательно)
BOT_TOKEN=

# ——— URLs ———
# Публичный URL приложения (для инвайт-ссылок и кнопки «Играть»). При деплое: HTTPS.
BASE_URL=http://localhost:5173
# URL бэкенда (API + WebSocket). Для приложения задаётся отдельно через VITE_API_URL при сборке.
API_URL=http://localhost:3000

# Публичный HTTPS-URL сайта (без слэша в конце). Нужен серверу для /robots.txt и /sitemap.xml.
# На проде совпадает с VITE_BASE_URL.
# BASE_URL=https://gamehubparty.ru

# ——— Фронт (скопируй в app/.env.production или задай в CI перед npm run build) ———
# VITE_API_URL=https://gamehubparty.ru
# VITE_BASE_URL=https://gamehubparty.ru
# VITE_BOT_USERNAME=твой_бот (без @)
# Опционально: абсолютная ссылка на OG-картинку 1200×630 (PNG/JPG) для соцсетей
# VITE_OG_IMAGE=https://gamehubparty.ru/og-cover.png
# Временно отключить рекламу (тесты): true | 1
# VITE_ADS_DISABLED=true

# ——— Сервер ———
PORT=3000
# Пароль админки API (/api/admin/*). В проде обязателен.
# ADMIN_PASSWORD=
# Разрешённые origin для CORS/socket (через запятую).
# ALLOWED_ORIGINS=https://gamehubparty.ru,https://www.gamehubparty.ru

# Секрет для JWT (регистрация по почте). В проде задайте длинную случайную строку.
# JWT_SECRET=
# Опционально: принудительный origin только для robots/sitemap.
# Если не задан, сервер использует host текущего запроса.
# SITEMAP_BASE_URL=https://gamehubparty.ru
# Опционально: путь к accounts.json (по умолчанию в GAMEHUB_DATA_DIR)
# ACCOUNTS_FILE=

# Постоянная папка для stats.json и feedback.jsonl (иначе при каждом деплое Docker/Railway счётчики обнуляются).
# Пример: GAMEHUB_DATA_DIR=/var/data/gamehub и смонтировать volume на этот путь.
# Опционально: STATS_FILE и FEEDBACK_FILE — полные пути к файлам (перекрывают расположение по GAMEHUB_DATA_DIR).
# GAMEHUB_DATA_DIR=

# ——— SEO / Яндекс.Вебмастер (после деплоя — только вручную в кабинете Яндекса) ———
# 1) Указать sitemap: https://ТВОЙ_ДОМЕН/sitemap.xml
# 2) Файл верификации уже в app/public/yandex_*.html — должен открываться с корня сайта
# Подробнее: seo/README.md
