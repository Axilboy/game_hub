# ——— Telegram ———
# Токен бота от @BotFather (обязательно)
BOT_TOKEN=

# ——— URLs ———
# Публичный URL приложения (для инвайт-ссылок и кнопки «Играть»). При деплое: HTTPS.
BASE_URL=http://localhost:5173
# URL бэкенда (API + WebSocket). Для приложения задаётся отдельно через VITE_API_URL при сборке.
API_URL=http://localhost:3000

# Для фронта (Mini App): URL бэкенда. В dev совпадает с API_URL.
# VITE_API_URL=http://localhost:3000
# Имя бота для инвайт-ссылок (без @): t.me/BOT_USERNAME?start=...
# VITE_BOT_USERNAME=

# ——— Сервер ———
PORT=3000
